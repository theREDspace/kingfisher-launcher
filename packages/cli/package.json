{
  "name": "@redspace/kingfisher-launcher",
  "version": "0.1.2",
  "type": "module",
  "bin": {
    "kingfisher-launcher": "./dist/index.js"
  },
  "files": [
    "dist",
    "public"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/copy-app-dist.mjs && tsup src/index.ts --format esm --clean",
    "prepublishOnly": "node scripts/copy-app-dist.mjs && tsup src/index.ts --format esm --clean",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/theREDspace/kingfisher-launcher.git"
  },
  "bugs": {
    "url": "https://github.com/theREDspace/kingfisher-launcher/issues"
  },
  "homepage": "https://github.com/theREDspace/kingfisher-launcher#readme",
  "author": "REDspace",
  "license": "MIT",
  "description": "Launch and sideload apps on Comcast Xfinity X1 devices registered in IBIS — an unofficial open-source CLI that opens a local web UI for device selection, app launching, and screen preview.",
  "keywords": [
    "comcast",
    "xfinity",
    "x1",
    "Xi6",
    "XiOne",
    "ibis",
    "kingfisher",
    "sideload",
    "sideloading",
    "app-launcher",
    "launcher",
    "set-top-box",
    "stb",
    "rdk",
    "device-testing",
    "developer-tools",
    "cli"
  ],
  "dependencies": {
    "commander": "^15.0.0",
    "express": "^5.2.1",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsup": "^8.5.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
